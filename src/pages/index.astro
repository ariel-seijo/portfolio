---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/sections/Navbar.astro";
import AnimatedCounter from "@components/react/AnimatedCounter.jsx";

const sections = [
  { id: "perfil", number: "02", title: "Perfil" },
  { id: "experiencia", number: "03", title: "Experiencia" },
  { id: "proyectos", number: "04", title: "Proyectos" },
  { id: "contacto", number: "05", title: "Contacto" },
];
---

<BaseLayout
  title="Ariel Seijo — Full Stack Engineer"
  description="Desarrollador Full Stack especializado en Aplicaciones Web. Soluciones a problemas reales que equilibran experiencia de usuario, accesibilidad, diseño, SEO, seguridad y performance."
>
  <Navbar />

  <main class="snap-container">
    <!-- Hero Section -->
    <section id="hero" class="snap-section hero-section">
      <div class="hero-grid">
        <div class="hero-content">
          <h1 class="hero-title">
            Hugo Ariel Seijo<br /><span class="hero-title-accent"
              >Desarrollador Full Stack</span
            >
          </h1>
          <p class="hero-description">
            Soluciones a problemas reales que equilibran experiencia de usuario,
            accesibilidad, diseño, SEO, seguridad y performance.
          </p>

          <div class="hero-actions">
            <a href="#proyectos" class="btn btn-primary">Ver proyectos</a>
            <a href="#contacto" class="btn btn-secondary">Contactar</a>
            <a href="/cv.pdf" class="btn btn-ghost" download>
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M8 11L8 1M8 11L5 8M8 11L11 8"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M2 13H14"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
              Descargar CV
            </a>
          </div>
        </div>

        <div class="hero-avatar">
          <img
            src="/avatar-img.webp"
            alt="Ariel Seijo"
            width="400"
            height="400"
          />
        </div>
      </div>
    </section>

    <!-- Other Sections -->
    {
      sections.map((section, i) => (
        <section
          id={section.id}
          class:list={["snap-section", i % 2 === 1 ? "snap-section--alt" : ""]}
        >
          <div class="section-content">
            <span class="section-number">{section.number}</span>
            <h2 class="section-title">{section.title}</h2>
            <div class="section-line" aria-hidden="true" />
          </div>
        </section>
      ))
    }
  </main>
</BaseLayout>

<style>
  /* =============================================
     HERO SECTION
     ============================================= */

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: stretch;
    max-width: 1200px;
    width: 100%;
    padding: var(--content-padding);
    animation: fade-in-up 0.8s var(--ease-out-expo) forwards;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-5);
  }

  /* ---- Avatar ---- */
  .hero-avatar {
    display: flex;
    justify-content: center;
    border-radius: 20px;
    overflow: hidden;
    min-height: 0;
  }

  .hero-avatar img {
    max-width: 100%;
    max-height: 100%;
    object-fit: cover;
  }

  .hero-overline {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0;
  }

  .hero-title {
    font-size: var(--text-hero);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
  }

  .hero-title-accent {
    font-size: 3.2rem;
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0;
  }

  .hero-description {
    font-size: 1rem;
    color: var(--color-text-tertiary);
    line-height: 1.7;
    max-width: 34rem;
    margin: 0;
  }

  /* ---- Buttons ---- */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 12px;
    text-decoration: none;
    transition:
      background 0.2s var(--ease-out-quint),
      color 0.2s var(--ease-out-quint),
      border-color 0.2s var(--ease-out-quint),
      transform 0.15s var(--ease-out-quint);
    cursor: pointer;
    white-space: nowrap;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-text-primary);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .btn-secondary {
    background: var(--color-accent-muted);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-active);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-hover-2);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid transparent;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .btn-ghost:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
    border-color: var(--color-border-default);
  }

  /* ---- Stats / Counters ---- */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: var(--space-10);
    margin-top: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-default);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-avatar {
      order: -1;
      max-width: 280px;
      aspect-ratio: 1;
      justify-self: center;
    }
  }

  @media (max-width: 640px) {
    .hero-content {
      gap: var(--space-4);
    }

    .hero-subtitle {
      font-size: 1.05rem;
    }

    .hero-description {
      font-size: 0.9375rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }

    .hero-stats {
      gap: var(--space-6);
      justify-content: flex-start;
    }

    .hero-avatar {
      max-width: 220px;
      aspect-ratio: 1;
    }
  }
</style>

<style is:global>
  /* ---- Scroll-snap container ---- */
  .snap-container {
    height: 100vh;
    height: 100dvh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: rgb(255 255 255 / 0.08) transparent;
  }

  .snap-container::-webkit-scrollbar {
    width: 5px;
  }

  .snap-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .snap-container::-webkit-scrollbar-thumb {
    background: rgb(255 255 255 / 0.06);
    border-radius: 3px;
  }

  .snap-container::-webkit-scrollbar-thumb:hover {
    background: rgb(255 255 255 / 0.12);
  }

  /* ---- Sections ---- */
  .snap-section {
    height: 100vh;
    height: 100dvh;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .snap-section--alt {
    background: rgb(255 255 255 / 0.008);
  }

  /* ---- Section content (placeholder for other sections) ---- */
  .section-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .section-number {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .section-title {
    font-size: var(--text-display);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .section-line {
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    opacity: 0.5;
  }

  /* ---- AnimatedCounter ---- */
  .animated-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }

  .animated-counter__number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .animated-counter__label {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-text-tertiary);
    letter-spacing: 0.01em;
  }

  @media (max-width: 640px) {
    .animated-counter__number {
      font-size: 1.75rem;
    }
  }
</style>
