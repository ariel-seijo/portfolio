---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/sections/Navbar.astro";
import Profile from "@components/sections/Profile.astro";
import ProjectsSection from "@components/sections/ProjectsSection.astro";

import ContactForm from "@components/react/ContactForm.jsx";
---

<BaseLayout
  title="Ariel Seijo — Full Stack Engineer"
  description="Desarrollador Full Stack especializado en Aplicaciones Web. Soluciones a problemas reales que equilibran experiencia de usuario, accesibilidad, diseño, SEO, seguridad y performance."
>
  <Navbar />

  <main class="page-container">
    <!-- Hero Section -->
    <section id="hero" class="section-wrapper hero-section">
      <div class="hero-grid">
        <div class="hero-content">
          <h1 class="hero-title">
            Hugo Ariel Seijo<br /><span class="hero-title-accent"
              >Desarrollador Full Stack</span
            >
          </h1>
          <p class="hero-description">
            Construyo software que funciona tan bien como se ve.
          </p>

          <div class="hero-actions">
            <a href="#proyectos" class="btn btn-primary">Ver experiencia</a>
            <a href="#contacto" class="btn btn-secondary">Contactar</a>
            <a href="/cv.pdf" class="btn btn-ghost" download>
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M8 11L8 1M8 11L5 8M8 11L11 8"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M2 13H14"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
              Descargar CV
            </a>
          </div>
        </div>

        <div class="hero-avatar">
          <img
            src="/avatar-img.webp"
            alt="Ariel Seijo"
            width="400"
            height="400"
          />
        </div>
      </div>
    </section>

    <!-- Profile Section -->
    <Profile />

    <!-- Experience Section -->
    <ProjectsSection />

    <!-- Contact Section -->
    <ContactForm client:load />
  </main>
</BaseLayout>

<style>
  /* =============================================
     HERO SECTION
     ============================================= */

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(var(--space-8), 4vw, var(--space-12));
    align-items: stretch;
    max-width: 1200px;
    width: 100%;
    padding: var(--content-padding);
    animation: fade-in-up 0.8s var(--ease-out-expo) forwards;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-6);
    min-width: 0;
  }

  /* ---- Avatar ---- */
  .hero-avatar {
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 20px;
    overflow: hidden;
  }

  .hero-avatar img {
    object-fit: cover;
  }

  .hero-overline {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 3vw + 0.3rem, 2rem);
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0;
  }

  .hero-title {
    font-size: var(--text-hero);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 0.85;
    margin: 0;
  }

  .hero-title-accent {
    font-size: clamp(1.5rem, 4vw + 0.3rem, 3.2rem);
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 2vw + 0.2rem, 0.875rem);
    font-weight: 500;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0;
  }

  .hero-description {
    font-size: clamp(0.875rem, 2.5vw + 0.2rem, 1rem);
    color: var(--color-text-tertiary);
    line-height: 1.7;
    max-width: 34rem;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-5);
  }

  /* ---- Stats / Counters ---- */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: var(--space-10);
    margin-top: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-default);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .hero-avatar {
      display: none;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-content {
      align-items: center;
      text-align: center;
    }

    .hero-title {
      font-size: clamp(2.8rem, 8vw + 0.5rem, 5.5rem);
    }

    .hero-title-accent {
      font-size: clamp(2rem, 6vw + 0.3rem, 4rem);
    }

    .hero-description {
      font-size: clamp(1rem, 3vw + 0.3rem, 1.35rem);
      margin-inline: auto;
      max-width: 44rem;
    }

    .hero-actions {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      height: 100vh;
    }
    .hero-grid {
      place-items: center;
    }

    .hero-content {
      gap: var(--space-4);
      justify-content: center;
    }

    .hero-title {
      font-size: clamp(2.3rem, 3.5vw, 2rem);
    }

    .hero-title-accent {
      font-size: clamp(1.6rem, 3.5vw, 2rem);
    }
    .hero-description {
      font-size: clamp(0.875rem, 3.5vw, 1rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      justify-content: center;
    }

    .hero-stats {
      gap: var(--space-6);
      justify-content: center;
    }
  }
</style>

<style is:global>
  /* ---- Page container ---- */
  .page-container {
    position: relative;
    z-index: 1;
  }

  /* ---- Section wrapper ---- */
  .section-wrapper {
    position: relative;
    max-width: 1200px;
    gap: var(--space-16);
    margin-inline: auto;
    margin-bottom: 100px;
    padding: var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: center;
    scroll-margin-top: 0.5rem;
  }

  .section-wrapper--alt {
    background: rgb(255 255 255 / 0.008);
  }

  /* ---- Hero overrides ---- */
  .hero-section {
    min-height: 100vh;
    min-height: 100dvh;
    max-width: none;
    margin-inline: 0;
    padding-block: 0;
  }

  /* ---- AnimatedCounter ---- */
  .animated-counter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }

  .animated-counter__number {
    font-size: clamp(1.5rem, 4vw + 0.3rem, 2.5rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .animated-counter__label {
    font-size: clamp(0.6875rem, 1.5vw + 0.15rem, 0.8125rem);
    font-weight: 400;
    color: var(--color-text-tertiary);
    letter-spacing: 0.01em;
  }

  @media (max-width: 640px) {
    .section-wrapper {
      min-height: auto;
      max-width: 100%;
      padding-block: var(--space-10);
    }
  }
</style>
