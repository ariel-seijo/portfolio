---
export interface Props {
  class?: string;
  width?: number;
  height?: number;
}
const { class: className, width = 40, height = 40 } = Astro.props;
---
<svg
  viewBox="0 0 40 40"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  width={width}
  height={height}
>
  <circle cx="20" cy="20" r="2.5" fill="#58C4DC" />
  <ellipse
    cx="20" cy="20" rx="12" ry="4.5"
    stroke="#58C4DC" stroke-width="1.5" fill="none" opacity="0.9"
  />
  <ellipse
    cx="20" cy="20" rx="12" ry="4.5"
    stroke="#58C4DC" stroke-width="1.5" fill="none" opacity="0.9"
    transform="rotate(60 20 20)"
  />
  <ellipse
    cx="20" cy="20" rx="12" ry="4.5"
    stroke="#58C4DC" stroke-width="1.5" fill="none" opacity="0.9"
    transform="rotate(120 20 20)"
  />
</svg>
