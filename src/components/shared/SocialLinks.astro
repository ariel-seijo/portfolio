---
import { cn } from "@utils/cn";
import type { SOCIAL_LINKS } from "@data/social";

export interface SocialLink {
  label: string;
  href: string;
  icon: string;
}

export interface Props {
  links: readonly SocialLink[];
  class?: string;
  size?: "sm" | "md";
}

const { links, class: className, size = "md" } = Astro.props;
---

<div class={cn("social-links", `social-${size}`, className)}>
  {links.map((link) => (
    <a
      href={link.href}
      class="social-link"
      aria-label={link.label}
      rel="noopener noreferrer"
      target="_blank"
    >
      <span class="social-icon" data-icon={link.icon}>
        {link.icon === "email" && (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        )}
        {link.icon === "linkedin" && (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        )}
        {link.icon === "github" && (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        )}
      </span>
      <span class="social-label">{link.label}</span>
    </a>
  ))}
</div>

<style>
  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: 10px;
    color: var(--color-text-secondary);
    font-size: var(--text-body-sm);
    font-weight: 500;
    transition: all 0.2s var(--ease-in-out-circ);
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-surface);
  }

  .social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-border-hover);
    transform: translateX(4px);
    background: var(--color-bg-elevated);
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .social-sm .social-link {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-caption);
    border-radius: 8px;
  }
</style>
