---
export interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
}

const { title, subtitle, align = "left", class: className } = Astro.props;
---

<div class:list={["section-heading", `align-${align}`, className]}>
  <h2 class="heading-title">{title}</h2>
  {subtitle && <p class="heading-subtitle">{subtitle}</p>}
  <div class="heading-line" aria-hidden="true"></div>
</div>

<style>
  .section-heading {
    margin-bottom: var(--space-12);
  }

  .align-left {
    text-align: left;
  }

  .align-center {
    text-align: center;
  }

  .align-center .heading-line {
    margin: var(--space-4) auto 0;
  }

  .heading-title {
    font-size: var(--text-display);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .heading-subtitle {
    margin-top: var(--space-3);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 36rem;
  }

  .heading-line {
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    margin-top: var(--space-4);
    opacity: 0.8;
  }
</style>
