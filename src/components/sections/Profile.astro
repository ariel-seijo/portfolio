---
import AnimatedCounter from "@components/react/AnimatedCounter.jsx";
import TechCardGrid from "@components/react/TechCardGrid.jsx";
---

<section class="section-wrapper profile-section">
  <div class="section-heading" id="perfil">
    <h2 class="title-block">
      <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
      <span class="title-main">Sobre mí</span>
      <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
    </h2>
  </div>

  <div class="profile-grid stagger-children">
    <!-- Terminal Frame + Avatar -->
    <div class="terminal-frame stagger-1">
      <div class="terminal-frame-inner">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--yellow" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--green" aria-hidden="true"
          ></span>
          <span class="terminal-title">arielseijo — bash — 80×24</span>
        </div>
        <div class="terminal-body">
          <img
            src="/avatar-profile2.webp"
            alt="Ariel Seijo"
            class="terminal-avatar"
            width="320"
            height="400"
          />
          <div class="terminal-scanline" aria-hidden="true"></div>
        </div>
        <div class="terminal-glow" aria-hidden="true"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="profile-content">
      <div class="profile-content-inner stagger-children">
        <h2 class="title-block stagger-1">
          <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
          <span class="title-main">Desarrollador Full Stack</span>
          <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
        </h2>

        <p class="profile-subtitle stagger-2">
          Diseño, desarrollo, pruebo y despliego aplicaciones web atractivas y
          funcionales, que resuelven necesidades de la manera más eficiente.
        </p>

        <div class="stats-row stagger-3">
          <div class="stat-card">
            <AnimatedCounter
              target={4}
              prefix="+"
              label="Años programando"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--alt">
            <AnimatedCounter
              target={999}
              prefix="+"
              label="Bugs arreglados"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--cyan">
            <AnimatedCounter
              target={300}
              prefix="+"
              label="Commits realizados"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--red">
            <AnimatedCounter
              target={3}
              prefix="+"
              label="Proyectos completados"
              duration={2500}
              client:load
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="tech-section">
    <div class="tech-heading-wrapper stagger-children">
      <h2 class="title-block stagger-1">
        <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
        <span class="title-main">Tecnologías</span>
        <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
      </h2>
    </div>

    <TechCardGrid client:load />
  </div>

  <div class="education-section">
    <div class="tech-heading-wrapper stagger-children">
      <h2 class="title-block stagger-1">
        <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
        <span class="title-main">Educación</span>
        <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
      </h2>
    </div>

    <div class="edu-card">
      <div class="edu-card__bg" aria-hidden="true">
        <svg
          class="edu-card__cap"
          viewBox="0 0 120 120"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M60 20L10 45l50 25 50-25L60 20z"
            stroke="currentColor"
            stroke-width="2"
            fill="none"></path>
          <path
            d="M60 45v30M35 75l-3 8h56l-3-8"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"></path>
          <path
            d="M10 45v20l50 25"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"></path>
        </svg>
      </div>

      <div class="edu-card__inner">
        <div class="edu-info">
          <h3 class="edu-degree">Técnico Superior en Desarrollo de Software</h3>
          <div class="edu-institution-row">
            <span class="edu-institution"
              >Instituto de Formación Técnica Superior Nº4</span
            >
          </div>
          <span class="edu-address">Murguiondo 2105, Mataderos, CABA</span>
          <div class="edu-meta">
            <span class="edu-year">2022 — 2024</span>
            <span class="edu-status">
              <span class="edu-status__dot" aria-hidden="true"></span>
              Graduado
            </span>
          </div>
        </div>

        <div class="edu-highlight">
          <div class="edu-gpa-ring">
            <svg
              class="edu-gpa-ring__svg"
              viewBox="0 0 100 100"
              aria-hidden="true"
            >
              <circle
                class="edu-gpa-ring__track"
                cx="50"
                cy="50"
                r="44"
                fill="none"
                stroke-width="3"></circle>
              <!-- ~93% of circumference for 9.30/10 -->
              <circle
                class="edu-gpa-ring__fill"
                cx="50"
                cy="50"
                r="44"
                fill="none"
                stroke-width="3"
                stroke-dasharray="276.46"
                stroke-dashoffset="19.35"
                stroke-linecap="round"></circle>
            </svg>
            <div class="edu-gpa-ring__content">
              <span class="edu-gpa-ring__value">9,30</span>
              <span class="edu-gpa-ring__label">Promedio</span>
            </div>
          </div>

          <a
            href="https://sisfet-firma.educacion.gob.ar/d/1086579Oq5ptSeqklCD5LAY"
            class="edu-cta"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 2h7l3 3v9a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1z"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linejoin="round"></path>
              <path
                d="M10 2v3h3M8 8v4M6 10l2 2 2-2"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Ver título
          </a>
        </div>
      </div>

      <div class="edu-card__shimmer" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .profile-section {
    overflow: hidden;
    flex-direction: column;
  }

  .section-heading {
    padding: 0 var(--content-padding);
  }

  .section-heading .title-main {
    font-size: clamp(2.2rem, 6vw, 4rem);
  }

  /* ---- Grid ---- */
  .profile-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--space-12);
    align-items: center;
    max-width: 1000px;
    width: 100%;
    padding-inline: var(--content-padding);
  }

  /* =============================================
     TERMINAL FRAME
     ============================================= */

  .terminal-frame {
    position: relative;
    background: linear-gradient(
      160deg,
      rgb(20 20 28 / 0.9) 0%,
      rgb(14 14 20 / 0.95) 100%
    );
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.08);
    overflow: hidden;
    transition:
      border-color 0.4s var(--ease-out-quint),
      box-shadow 0.4s var(--ease-out-quint),
      transform 0.5s var(--ease-out-quint);
  }

  .terminal-frame-inner {
    animation: float 18s ease-in-out infinite;
  }

  .terminal-frame:hover {
    border-color: rgb(139 92 246 / 0.3);
    box-shadow:
      0 0 30px rgb(139 92 246 / 0.08),
      0 0 60px rgb(139 92 246 / 0.03);
    transform: translateY(-3px);
  }

  .terminal-frame:hover .terminal-glow {
    opacity: 1;
  }

  .terminal-glow {
    position: absolute;
    inset: -1px;
    border-radius: 14px;
    background: linear-gradient(
      135deg,
      rgb(139 92 246 / 0.12) 0%,
      transparent 40%,
      transparent 60%,
      rgb(139 92 246 / 0.08) 100%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quint);
    pointer-events: none;
    z-index: 2;
  }

  /* ---- Terminal header ---- */
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 14px;
    background: rgb(0 0 0 / 0.25);
    border-bottom: 1px solid rgb(255 255 255 / 0.04);
    position: relative;
    z-index: 3;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .terminal-dot--red {
    background: #ff5f57;
    box-shadow: 0 0 6px rgb(255 95 87 / 0.3);
  }
  .terminal-dot--yellow {
    background: #febc2e;
    box-shadow: 0 0 6px rgb(254 188 46 / 0.3);
  }
  .terminal-dot--green {
    background: #28c840;
    box-shadow: 0 0 6px rgb(40 200 64 / 0.3);
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    color: rgb(255 255 255 / 0.35);
    margin-left: 10px;
    letter-spacing: 0.03em;
    user-select: none;
  }

  /* ---- Terminal body ---- */
  .terminal-body {
    position: relative;
    padding: 10px;
    z-index: 1;
  }

  .terminal-avatar {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    position: relative;
    z-index: 1;
  }

  .terminal-scanline {
    position: absolute;
    inset: 10px;
    border-radius: 8px;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgb(0 0 0 / 0.03) 50%
    );
    background-size: 100% 4px;
    pointer-events: none;
    z-index: 2;
  }

  /* =============================================
     CONTENT
     ============================================= */

  .profile-content {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .profile-content-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    width: 100%;
  }

  /* ---- Title block ---- */
  .title-block {
    margin: 0;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .bracket {
    font-family: var(--font-mono);
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.7;
    transition:
      opacity 0.4s var(--ease-out-quint),
      color 0.4s var(--ease-out-quint);
  }

  .bracket--open {
    margin-right: 0.15em;
  }

  .bracket--close {
    margin-left: 0.15em;
  }

  .title-block:hover .bracket {
    opacity: 1;
    color: var(--color-accent);
  }

  .title-main {
    font-size: clamp(1rem, 7vw, 2.8rem);
    color: var(--color-text-);
    font-weight: 800;
    line-height: 0.9;
  }

  /* ---- Subtitle ---- */
  .profile-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    padding-bottom: var(--space-5);
  }

  /* =============================================
     STAT CARDS
     ============================================= */

  .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .stat-card {
    position: relative;
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    padding: var(--space-5) var(--space-5) var(--space-4);
    overflow: hidden;
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(139 92 246 / 0.06) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
    pointer-events: none;
  }

  .stat-card--alt::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(74 222 128 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card:hover {
    border-color: rgb(139 92 246 / 0.3);
    transform: translateY(-4px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(139 92 246 / 0.05);
    background: rgb(19 19 23 / 0.6);
  }

  .stat-card--alt:hover {
    border-color: rgb(74 222 128 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(74 222 128 / 0.06);
  }

  .stat-card--cyan::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(34 211 238 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--cyan:hover {
    border-color: rgb(34 211 238 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(34 211 238 / 0.06);
  }

  .stat-card--red::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(248 113 113 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--red:hover {
    border-color: rgb(248 113 113 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(248 113 113 / 0.06);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  /* ---- Override AnimatedCounter inside cards ---- */
  .stat-card :global(.animated-counter) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }

  .stat-card :global(.animated-counter__number) {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-card--alt :global(.animated-counter__number) {
    color: #4ade80;
  }

  .stat-card :global(.animated-counter__label) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .stat-card--alt :global(.animated-counter__label) {
    color: #6ee7b0;
  }

  .stat-card--cyan :global(.animated-counter__number) {
    color: #22d3ee;
  }

  .stat-card--cyan :global(.animated-counter__label) {
    color: #67e8f9;
  }

  .stat-card--red :global(.animated-counter__number) {
    color: #f87171;
  }

  .stat-card--red :global(.animated-counter__label) {
    color: #fca5a5;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 860px) {
    .profile-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      max-width: 560px;
    }

    .terminal-frame {
      max-width: 320px;
      justify-self: center;
    }

    .title-main {
      font-size: clamp(2.4rem, 9vw, 3.8rem);
    }

    .section-heading .title-main {
      font-size: clamp(2.2rem, 6vw, 4rem);
    }

    .profile-content-inner {
      gap: var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .profile-grid {
      padding: var(--space-6) var(--space-6);
      gap: var(--space-8);
    }

    .terminal-frame {
      max-width: 260px;
    }

    .terminal-header {
      padding: 10px 12px;
    }

    .terminal-dot {
      width: 10px;
      height: 10px;
    }

    .terminal-title {
      font-size: 0.625rem;
      margin-left: 6px;
    }

    .terminal-body {
      padding: 8px;
    }

    .title-main {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .section-heading .title-main {
      font-size: clamp(1.8rem, 8vw, 2.8rem);
    }

    .profile-subtitle {
      font-size: var(--text-body-sm);
      padding-bottom: var(--space-4);
    }

    .stats-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .stat-card :global(.animated-counter__number) {
      font-size: 2rem;
    }
  }

  /* =============================================
     EDUCATION SECTION
     ============================================= */

  .education-section {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    max-width: 1000px;
    width: 100%;
    padding: 0 var(--content-padding);
  }

  /* ---- Card ---- */
  .edu-card {
    position: relative;
    width: 100%;
    max-width: 780px;
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 20px;
    overflow: hidden;
    transition:
      border-color 0.5s var(--ease-out-quint),
      box-shadow 0.5s var(--ease-out-quint),
      transform 0.5s var(--ease-spring);
    animation: edu-enter 0.8s var(--ease-out-expo) forwards;
    opacity: 0;
    animation-delay: 0.3s;
  }

  @keyframes edu-enter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .edu-card:hover {
    border-color: rgb(139 92 246 / 0.25);
    box-shadow:
      0 8px 40px rgb(0 0 0 / 0.45),
      0 0 60px rgb(139 92 246 / 0.06);
    transform: translateY(-3px);
  }

  /* ---- Background decoration: graduation cap ---- */
  .edu-card__bg {
    position: absolute;
    top: -40px;
    right: -20px;
    z-index: 0;
    pointer-events: none;
    opacity: 0.035;
    transition: opacity 0.6s var(--ease-out-quint);
  }

  .edu-card:hover .edu-card__bg {
    opacity: 0.06;
  }

  .edu-card__cap {
    width: 240px;
    height: 240px;
    color: var(--color-accent);
  }

  /* ---- Inner layout ---- */
  .edu-card__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: center;
    padding: var(--space-12) var(--space-12);
  }

  /* ---- Shimmer border effect ---- */
  .edu-card__shimmer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s var(--ease-out-quint);
    background: radial-gradient(
      ellipse 60% 50% at 30% 50%,
      rgb(139 92 246 / 0.08) 0%,
      transparent 60%
    );
  }

  .edu-card:hover .edu-card__shimmer {
    opacity: 1;
  }

  /* ---- Left: Info ---- */
  .edu-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .edu-degree {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.3;
  }

  .edu-institution-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .edu-institution {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .edu-address {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.02em;
  }

  .edu-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .edu-year {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
  }

  .edu-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-success);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgb(74 222 128 / 0.08);
    border: 1px solid rgb(74 222 128 / 0.15);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }

  .edu-status__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    box-shadow: 0 0 8px rgb(74 222 128 / 0.6);
    animation: pulse-soft 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-soft {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 6px rgb(74 222 128 / 0.5);
    }
    50% {
      opacity: 0.6;
      box-shadow: 0 0 12px rgb(74 222 128 / 0.8);
    }
  }

  /* ---- Right: GPA ring + CTA ---- */
  .edu-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    flex-shrink: 0;
  }

  .edu-gpa-ring {
    position: relative;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .edu-gpa-ring__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .edu-gpa-ring__track {
    stroke: rgb(139 92 246 / 0.12);
  }

  .edu-gpa-ring__fill {
    stroke: var(--color-accent);
    filter: drop-shadow(0 0 6px rgb(139 92 246 / 0.4));
    transition:
