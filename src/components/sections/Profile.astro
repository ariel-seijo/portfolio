---
import AnimatedCounter from "@components/react/AnimatedCounter.jsx";

interface StackItem {
  name: string;
  icon: string;
}

interface StackCategory {
  label: string;
  items: StackItem[];
}

const STACK: StackCategory[] = [
  {
    label: "Frontend",
    items: [
      { name: "React", icon: "/tech-icons/react.svg" },
      { name: "Next.js", icon: "/tech-icons/nextjs.svg" },
      { name: "Astro", icon: "/tech-icons/astro.svg" },
      { name: "Tailwind CSS", icon: "/tech-icons/tailwindcss.svg" },
    ],
  },
  {
    label: "Backend",
    items: [
      { name: "Node.js", icon: "nodejs" },
      { name: "Prisma ORM", icon: "prisma" },
    ],
  },
  {
    label: "Base de datos",
    items: [{ name: "PostgreSQL", icon: "/tech-icons/postgresql.svg" }],
  },
  {
    label: "Lenguajes",
    items: [{ name: "TypeScript", icon: "/tech-icons/typescript.svg" }],
  },
  {
    label: "Herramientas",
    items: [
      { name: "Git", icon: "git" },
      { name: "GitHub", icon: "github" },
      { name: "Vercel", icon: "vercel" },
    ],
  },
  {
    label: "Testing",
    items: [{ name: "Vitest", icon: "vitest" }],
  },
];

const ICONS: Record<string, string> = {
  nodejs: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 1.85c-.27 0-.55.07-.8.2L4.22 5.87a1.6 1.6 0 0 0-.8 1.38v7.5c0 .57.3 1.1.8 1.38l6.98 3.82c.25.13.53.2.8.2.27 0 .55-.07.8-.2l6.98-3.82a1.6 1.6 0 0 0 .8-1.38v-7.5c0-.57-.3-1.1-.8-1.38L12.8 2.05a1.6 1.6 0 0 0-.8-.2Z" stroke="#539E43" stroke-width="1.5"/><path d="M7.5 9.5 12 12l4.5-2.5M12 12v7.5" stroke="#539E43" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M7.5 13.5 3 11l4.5 6 4.5-6-4.5 2.5Z" fill="#539E43" opacity=".6"/></svg>`,
  prisma: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M3.5 18.5 12 2l8.5 16.5L12 22 3.5 18.5Z" stroke="#5B67D2" stroke-width="1.5"/><path d="m12 22-2-8.5L17 8.5 12 22Z" fill="#5B67D2" opacity=".5"/></svg>`,
  git: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#F1502F" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="#F1502F" stroke-width="1.5"/><line x1="12" y1="2" x2="12" y2="9" stroke="#F1502F" stroke-width="1.5"/><line x1="12" y1="15" x2="12" y2="22" stroke="#F1502F" stroke-width="1.5"/><line x1="2" y1="12" x2="9" y2="12" stroke="#F1502F" stroke-width="1.5"/><line x1="15" y1="12" x2="22" y2="12" stroke="#F1502F" stroke-width="1.5"/></svg>`,
  github: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M15 22v-2.8c0-1 .3-2-1-2.7 3.5-.4 7.5-1.7 7.5-7.7a6 6 0 0 0-1.6-4.2 5.5 5.5 0 0 0-.2-4.3s-1.3-.4-4.3 1.6a14.8 14.8 0 0 0-7.8 0C4.5 0 3.2.4 3.2 1c-.8 1.3-.9 2.8-.2 4.2A6 6 0 0 0 1.5 9.5c0 6 4 7.3 7.5 7.7-1.3.7-1 1.7-1 2.7V22" stroke="#C9D1D9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  vercel: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="m12 2 10 17H2L12 2Z" stroke="#fff" stroke-width="1.5"/></svg>`,
  vitest: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2 3 7l9 5 9-5-9-5Z" stroke="#729B1B" stroke-width="1.5"/><path d="M3 17 12 22l9-5" stroke="#729B1B" stroke-width="1.5"/><path d="M3 12 12 17l9-5" stroke="#729B1B" stroke-width="1.5" opacity=".5"/></svg>`,
};
---

<section id="perfil" class="section-wrapper profile-section">
  <div class="profile-bg-pattern" aria-hidden="true"></div>

  <div class="profile-grid stagger-children">
    <!-- Terminal Frame + Avatar -->
    <div class="terminal-frame stagger-1">
      <div class="terminal-frame-inner">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--yellow" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--green" aria-hidden="true"
          ></span>
          <span class="terminal-title">arielseijo — bash — 80×24</span>
        </div>
        <div class="terminal-body">
          <img
            src="/avatar-profile2.webp"
            alt="Ariel Seijo"
            class="terminal-avatar"
            width="320"
            height="400"
          />
          <div class="terminal-scanline" aria-hidden="true"></div>
        </div>
        <div class="terminal-glow" aria-hidden="true"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="profile-content">
      <div class="profile-content-inner stagger-children">
        <h2 class="title-block stagger-1">
          <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
          <span class="title-main">Desarrollador Full Stack</span>
          <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
        </h2>

        <p class="profile-subtitle stagger-2">
          Diseño, desarrollo, pruebo y despliego aplicaciones web atractivas y
          funcionales, que resuelven necesidades de la manera más eficiente.
        </p>

        <div class="stats-row stagger-3">
          <div class="stat-card">
            <AnimatedCounter
              target={4}
              prefix="+"
              label="Años programando"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--alt">
            <AnimatedCounter
              target={999}
              prefix="+"
              label="Bugs arreglados"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--cyan">
            <AnimatedCounter
              target={300}
              prefix="+"
              label="Commits realizados"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--red">
            <AnimatedCounter
              target={3}
              prefix="+"
              label="Proyectos completados"
              duration={2500}
              client:load
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="stack-section">
    <div class="stack-heading-wrapper stagger-children">
      <h3 class="stack-heading stagger-2">Stack Principal</h3>
    </div>

    <div class="stack-grid stagger-children">
      {
        STACK.map((category, i) => (
          <div class={`stack-card stagger-${(i % 3) + 1}`}>
            <span class="stack-card-label">{category.label}</span>
            <div class="stack-card-pills">
              {category.items.map((item) => (
                <span class="pill">
                  {item.icon.startsWith("/") ? (
                    <img
                      src={item.icon}
                      alt=""
                      class="pill-icon"
                      width="14"
                      height="14"
                      loading="lazy"
                    />
                  ) : (
                    <span class="pill-icon" set:html={ICONS[item.icon] || ""} />
                  )}
                  {item.name}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .profile-section {
    overflow: hidden;
    flex-direction: column;
    gap: var(--space-12);
    padding-bottom: var(--space-24);
  }

  /* ---- Background pattern ---- */
  .profile-bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgb(139 92 246 / 0.04) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    mask-image: radial-gradient(
      ellipse 75% 55% at 50% 50%,
      black 20%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ---- Grid ---- */
  .profile-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--space-12);
    align-items: center;
    max-width: 1000px;
    width: 100%;
    padding: var(--space-10) var(--content-padding);
  }

  /* =============================================
     TERMINAL FRAME
     ============================================= */

  .terminal-frame {
    position: relative;
    background: linear-gradient(
      160deg,
      rgb(20 20 28 / 0.9) 0%,
      rgb(14 14 20 / 0.95) 100%
    );
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.08);
    overflow: hidden;
    transition:
      border-color 0.4s var(--ease-out-quint),
      box-shadow 0.4s var(--ease-out-quint),
      transform 0.5s var(--ease-out-quint);
  }

  .terminal-frame-inner {
    animation: float 18s ease-in-out infinite;
  }

  .terminal-frame:hover {
    border-color: rgb(139 92 246 / 0.3);
    box-shadow:
      0 0 30px rgb(139 92 246 / 0.08),
      0 0 60px rgb(139 92 246 / 0.03);
    transform: translateY(-3px);
  }

  .terminal-frame:hover .terminal-glow {
    opacity: 1;
  }

  .terminal-glow {
    position: absolute;
    inset: -1px;
    border-radius: 14px;
    background: linear-gradient(
      135deg,
      rgb(139 92 246 / 0.12) 0%,
      transparent 40%,
      transparent 60%,
      rgb(139 92 246 / 0.08) 100%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quint);
    pointer-events: none;
    z-index: 2;
  }

  /* ---- Terminal header ---- */
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 14px;
    background: rgb(0 0 0 / 0.25);
    border-bottom: 1px solid rgb(255 255 255 / 0.04);
    position: relative;
    z-index: 3;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .terminal-dot--red {
    background: #ff5f57;
    box-shadow: 0 0 6px rgb(255 95 87 / 0.3);
  }
  .terminal-dot--yellow {
    background: #febc2e;
    box-shadow: 0 0 6px rgb(254 188 46 / 0.3);
  }
  .terminal-dot--green {
    background: #28c840;
    box-shadow: 0 0 6px rgb(40 200 64 / 0.3);
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    color: rgb(255 255 255 / 0.35);
    margin-left: 10px;
    letter-spacing: 0.03em;
    user-select: none;
  }

  /* ---- Terminal body ---- */
  .terminal-body {
    position: relative;
    padding: 10px;
    z-index: 1;
  }

  .terminal-avatar {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    position: relative;
    z-index: 1;
  }

  .terminal-scanline {
    position: absolute;
    inset: 10px;
    border-radius: 8px;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgb(0 0 0 / 0.03) 50%
    );
    background-size: 100% 4px;
    pointer-events: none;
    z-index: 2;
  }

  /* =============================================
     CONTENT
     ============================================= */

  .profile-content {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .profile-content-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    width: 100%;
  }

  /* ---- Title block ---- */
  .title-block {
    margin: 0;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .bracket {
    font-family: var(--font-mono);
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.7;
    transition:
      opacity 0.4s var(--ease-out-quint),
      color 0.4s var(--ease-out-quint);
  }

  .bracket--open {
    margin-right: 0.15em;
  }

  .bracket--close {
    margin-left: 0.15em;
  }

  .title-block:hover .bracket {
    opacity: 1;
    color: var(--color-accent);
  }

  .title-main {
    font-size: clamp(1rem, 7vw, 2.8rem);
    color: var(--color-text-);
    font-weight: 800;
    line-height: 0.9;
  }

  /* ---- Subtitle ---- */
  .profile-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border-default);
    position: relative;
  }

  .profile-subtitle::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 48px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  /* =============================================
     STAT CARDS
     ============================================= */

  .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .stat-card {
    position: relative;
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    padding: var(--space-5) var(--space-5) var(--space-4);
    overflow: hidden;
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(139 92 246 / 0.06) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
    pointer-events: none;
  }

  .stat-card--alt::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(74 222 128 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card:hover {
    border-color: rgb(139 92 246 / 0.3);
    transform: translateY(-4px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(139 92 246 / 0.05);
    background: rgb(19 19 23 / 0.6);
  }

  .stat-card--alt:hover {
    border-color: rgb(74 222 128 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(74 222 128 / 0.06);
  }

  .stat-card--cyan::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(34 211 238 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--cyan:hover {
    border-color: rgb(34 211 238 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(34 211 238 / 0.06);
  }

  .stat-card--red::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(248 113 113 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--red:hover {
    border-color: rgb(248 113 113 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(248 113 113 / 0.06);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  /* ---- Override AnimatedCounter inside cards ---- */
  .stat-card :global(.animated-counter) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }

  .stat-card :global(.animated-counter__number) {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-card--alt :global(.animated-counter__number) {
    color: #4ade80;
  }

  .stat-card :global(.animated-counter__label) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .stat-card--alt :global(.animated-counter__label) {
    color: #6ee7b0;
  }

  .stat-card--cyan :global(.animated-counter__number) {
    color: #22d3ee;
  }

  .stat-card--cyan :global(.animated-counter__label) {
    color: #67e8f9;
  }

  .stat-card--red :global(.animated-counter__number) {
    color: #f87171;
  }

  .stat-card--red :global(.animated-counter__label) {
    color: #fca5a5;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 860px) {
    .profile-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      max-width: 560px;
    }

    .terminal-frame {
      max-width: 320px;
      justify-self: center;
    }

    .title-main {
      font-size: clamp(2.4rem, 9vw, 3.8rem);
    }

    .profile-content-inner {
      gap: var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .profile-grid {
      padding: var(--space-6) var(--space-5);
      gap: var(--space-6);
    }

    .terminal-frame {
      max-width: 260px;
    }

    .terminal-header {
      padding: 10px 12px;
    }

    .terminal-dot {
      width: 10px;
      height: 10px;
    }

    .terminal-title {
      font-size: 0.625rem;
      margin-left: 6px;
    }

    .terminal-body {
      padding: 8px;
    }

    .title-main {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .profile-subtitle {
      font-size: var(--text-body-sm);
      padding-bottom: var(--space-4);
    }

    .stats-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .stat-card :global(.animated-counter__number) {
      font-size: 2rem;
    }
  }

  /* =============================================
     STACK SECTION
     ============================================= */

  .stack-section {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    width: 100%;
    padding: 0 var(--content-padding);
  }

  .stack-heading-wrapper {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .stack-heading-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 var(--space-2);
  }

  .stack-heading {
    font-size: var(--text-display);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    margin: 0;
    position: relative;
    display: inline-block;
  }

  .stack-heading::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 50%;
    translate: -50%;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  /* ---- Grid ---- */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  /* ---- Card ---- */
  .stack-card {
    position: relative;
    background: rgb(19 19 23 / 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    padding: var(--space-4) var(--space-5);
    overflow: hidden;
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .stack-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 35%,
      rgb(139 92 246 / 0.04) 42%,
      rgb(139 92 246 / 0.1) 50%,
      rgb(139 92 246 / 0.04) 58%,
      transparent 65%
    );
    transform: translateX(-100%);
    transition: transform 0.7s var(--ease-out-quint);
    pointer-events: none;
    z-index: 1;
  }

  .stack-card:hover {
    border-color: rgb(139 92 246 / 0.25);
    transform: translateY(-3px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.3),
      0 0 40px rgb(139 92 246 / 0.04);
    background: rgb(19 19 23 / 0.55);
  }

  .stack-card:hover::after {
    transform: translateX(100%);
  }

  .stack-card-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin-bottom: var(--space-3);
  }

  .stack-card-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    position: relative;
    z-index: 2;
  }

  .stack-card .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0.25rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 500;
    background: var(--color-accent-muted);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-active);
    border-radius: 7px;
    transition:
      color 0.2s var(--ease-out-quint),
      background 0.2s var(--ease-out-quint),
      border-color 0.2s var(--ease-out-quint);
  }

  .stack-card .pill:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-hover-2);
  }

  .pill-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .pill-icon :global(img) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ---- Stack responsive ---- */
  @media (max-width: 860px) {
    .stack-grid {
