---
import AnimatedCounter from "@components/react/AnimatedCounter.jsx";
---

<section id="perfil" class="section-wrapper profile-section">
  <div class="profile-bg-pattern" aria-hidden="true"></div>

  <div class="profile-grid stagger-children">
    <!-- Terminal Frame + Avatar -->
    <div class="terminal-frame stagger-1">
      <div class="terminal-frame-inner">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--yellow" aria-hidden="true"
          ></span>
          <span class="terminal-dot terminal-dot--green" aria-hidden="true"
          ></span>
          <span class="terminal-title">arielseijo — bash — 80×24</span>
        </div>
        <div class="terminal-body">
          <img
            src="/avatar-profile2.webp"
            alt="Ariel Seijo"
            class="terminal-avatar"
            width="320"
            height="400"
          />
          <div class="terminal-scanline" aria-hidden="true"></div>
        </div>
        <div class="terminal-glow" aria-hidden="true"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="profile-content">
      <div class="profile-content-inner stagger-children">
        <h2 class="title-block stagger-1">
          <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
          <span class="title-main">Desarrollador Full Stack</span>
          <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
        </h2>

        <p class="profile-subtitle stagger-2">
          Diseño, desarrollo, pruebo y despliego aplicaciones web atractivas y
          funcionales, que resuelven necesidades de la manera más eficiente.
        </p>

        <div class="stats-row stagger-3">
          <div class="stat-card">
            <AnimatedCounter
              target={4}
              prefix="+"
              label="Años programando"
              duration={2500}
              client:load
            />
          </div>
          <div class="stat-card stat-card--alt">
            <AnimatedCounter
              target={1000}
              prefix="+"
              label="Bugs arreglados"
              duration={2800}
              client:load
            />
          </div>
          <div class="stat-card stat-card--cyan">
            <AnimatedCounter
              target={300}
              prefix="+"
              label="Commits realizados"
              duration={2600}
              client:load
            />
          </div>
          <div class="stat-card stat-card--red">
            <AnimatedCounter
              target={3}
              prefix="+"
              label="Proyectos completados"
              duration={3000}
              client:load
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .profile-section {
    overflow: hidden;
  }

  /* ---- Background pattern ---- */
  .profile-bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgb(139 92 246 / 0.04) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    mask-image: radial-gradient(
      ellipse 75% 55% at 50% 50%,
      black 20%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ---- Grid ---- */
  .profile-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--space-12);
    align-items: center;
    max-width: 1000px;
    width: 100%;
    padding: var(--space-10) var(--content-padding);
  }

  /* =============================================
     TERMINAL FRAME
     ============================================= */

  .terminal-frame {
    position: relative;
    background: linear-gradient(
      160deg,
      rgb(20 20 28 / 0.9) 0%,
      rgb(14 14 20 / 0.95) 100%
    );
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.08);
    overflow: hidden;
    transition:
      border-color 0.4s var(--ease-out-quint),
      box-shadow 0.4s var(--ease-out-quint),
      transform 0.5s var(--ease-out-quint);
  }

  .terminal-frame-inner {
    animation: float 18s ease-in-out infinite;
  }

  .terminal-frame:hover {
    border-color: rgb(139 92 246 / 0.3);
    box-shadow:
      0 0 30px rgb(139 92 246 / 0.08),
      0 0 60px rgb(139 92 246 / 0.03);
    transform: translateY(-3px);
  }

  .terminal-frame:hover .terminal-glow {
    opacity: 1;
  }

  .terminal-glow {
    position: absolute;
    inset: -1px;
    border-radius: 14px;
    background: linear-gradient(
      135deg,
      rgb(139 92 246 / 0.12) 0%,
      transparent 40%,
      transparent 60%,
      rgb(139 92 246 / 0.08) 100%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quint);
    pointer-events: none;
    z-index: 2;
  }

  /* ---- Terminal header ---- */
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 14px;
    background: rgb(0 0 0 / 0.25);
    border-bottom: 1px solid rgb(255 255 255 / 0.04);
    position: relative;
    z-index: 3;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .terminal-dot--red {
    background: #ff5f57;
    box-shadow: 0 0 6px rgb(255 95 87 / 0.3);
  }
  .terminal-dot--yellow {
    background: #febc2e;
    box-shadow: 0 0 6px rgb(254 188 46 / 0.3);
  }
  .terminal-dot--green {
    background: #28c840;
    box-shadow: 0 0 6px rgb(40 200 64 / 0.3);
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    color: rgb(255 255 255 / 0.35);
    margin-left: 10px;
    letter-spacing: 0.03em;
    user-select: none;
  }

  /* ---- Terminal body ---- */
  .terminal-body {
    position: relative;
    padding: 10px;
    z-index: 1;
  }

  .terminal-avatar {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    position: relative;
    z-index: 1;
  }

  .terminal-scanline {
    position: absolute;
    inset: 10px;
    border-radius: 8px;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgb(0 0 0 / 0.03) 50%
    );
    background-size: 100% 4px;
    pointer-events: none;
    z-index: 2;
  }

  /* =============================================
     CONTENT
     ============================================= */

  .profile-content {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .profile-content-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    width: 100%;
  }

  /* ---- Title block ---- */
  .title-block {
    margin: 0;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .bracket {
    font-family: var(--font-mono);
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.7;
    transition:
      opacity 0.4s var(--ease-out-quint),
      color 0.4s var(--ease-out-quint);
  }

  .bracket--open {
    margin-right: 0.15em;
  }

  .bracket--close {
    margin-left: 0.15em;
  }

  .title-block:hover .bracket {
    opacity: 1;
    color: var(--color-accent);
  }

  .title-main {
    font-size: clamp(1rem, 7vw, 2.8rem);
    color: var(--color-text-);
    font-weight: 800;
    line-height: 0.9;
  }

  /* ---- Subtitle ---- */
  .profile-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border-default);
    position: relative;
  }

  .profile-subtitle::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 48px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  /* =============================================
     STAT CARDS
     ============================================= */

  .stats-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .stat-card {
    position: relative;
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    padding: var(--space-5) var(--space-5) var(--space-4);
    overflow: hidden;
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(139 92 246 / 0.06) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
    pointer-events: none;
  }

  .stat-card--alt::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(74 222 128 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card:hover {
    border-color: rgb(139 92 246 / 0.3);
    transform: translateY(-4px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(139 92 246 / 0.05);
    background: rgb(19 19 23 / 0.6);
  }

  .stat-card--alt:hover {
    border-color: rgb(74 222 128 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(74 222 128 / 0.06);
  }

  .stat-card--cyan::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(34 211 238 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--cyan:hover {
    border-color: rgb(34 211 238 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(34 211 238 / 0.06);
  }

  .stat-card--red::before {
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgb(248 113 113 / 0.06) 0%,
      transparent 70%
    );
  }

  .stat-card--red:hover {
    border-color: rgb(248 113 113 / 0.35);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.4),
      0 0 40px rgb(248 113 113 / 0.06);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  /* ---- Override AnimatedCounter inside cards ---- */
  .stat-card :global(.animated-counter) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }

  .stat-card :global(.animated-counter__number) {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-card--alt :global(.animated-counter__number) {
    color: #4ade80;
  }

  .stat-card :global(.animated-counter__label) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .stat-card--alt :global(.animated-counter__label) {
    color: #6ee7b0;
  }

  .stat-card--cyan :global(.animated-counter__number) {
    color: #22d3ee;
  }

  .stat-card--cyan :global(.animated-counter__label) {
    color: #67e8f9;
  }

  .stat-card--red :global(.animated-counter__number) {
    color: #f87171;
  }

  .stat-card--red :global(.animated-counter__label) {
    color: #fca5a5;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 860px) {
    .profile-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      max-width: 560px;
    }

    .terminal-frame {
      max-width: 320px;
      justify-self: center;
    }

    .title-main {
      font-size: clamp(2.4rem, 9vw, 3.8rem);
    }

    .profile-content-inner {
      gap: var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .profile-grid {
      padding: var(--space-6) var(--space-5);
      gap: var(--space-6);
    }

    .terminal-frame {
      max-width: 260px;
    }

    .terminal-header {
      padding: 10px 12px;
    }

    .terminal-dot {
      width: 10px;
      height: 10px;
    }

    .terminal-title {
      font-size: 0.625rem;
      margin-left: 6px;
    }

    .terminal-body {
      padding: 8px;
    }

    .title-main {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .profile-subtitle {
      font-size: var(--text-body-sm);
      padding-bottom: var(--space-4);
    }

    .stats-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .stat-card :global(.animated-counter__number) {
      font-size: 2rem;
    }
  }

  /* ---- Respect reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .terminal-frame-inner {
      animation: none;
    }

    .stat-card {
      transition: none;
    }
  }
</style>
