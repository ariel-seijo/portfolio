---
import ProjectCardGrid from "@components/react/ProjectCardGrid.jsx";
import ProjectLightbox from "@components/react/ProjectLightbox.jsx";
import { PROJECTS } from "@data/projects";
---

<section id="proyectos" class="section-wrapper projects-section">
  <ProjectCardGrid projects={PROJECTS} client:load />
  <ProjectLightbox projects={PROJECTS} client:load />
</section>

<style>
  .projects-section {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: var(--space-8) var(--content-padding);
  }

  @media (max-width: 640px) {
    .projects-section {
      padding: var(--space-6) var(--space-4);
    }
  }
</style>
