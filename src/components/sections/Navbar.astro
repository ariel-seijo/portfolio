---
import { NAV_LINKS } from "@data/site";
---

<nav class="nav" aria-label="Navegación principal">
  <div class="nav-inner">
    <div class="nav-track">
      {
        NAV_LINKS.map((link) => (
          <a href={link.href} class="nav-link" data-section={link.id}>
            {link.label}
          </a>
        ))
      }
      <div class="nav-indicator" aria-hidden="true"></div>
    </div>

    <a href="/cv.pdf" class="nav-cv-btn" download>
      <svg
        width="14"
        height="14"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M8 11V1M8 11L5 8M8 11L11 8"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M1 14h14"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
      CV
    </a>
  </div>
</nav>

<script>
  function initNav() {
    const links = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    const indicator = document.querySelector<HTMLDivElement>(".nav-indicator");
    const container = document.querySelector<HTMLElement>(".page-container");
    if (!links.length || !indicator || !container) return;

    // Grab all snap sections from the container
    const sections = [
      ...container.querySelectorAll<HTMLElement>("section[id]"),
    ];
    if (!sections.length) return;

    // Start empty — setActive will populate on first call
    let activeId = "";

    // --- Indicator helpers ---
    function moveIndicator(link: HTMLAnchorElement | null) {
      if (!link || !indicator) return;
      const track = link.parentElement!;
      const trackRect = track.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();

      // Indicator has left:5px in CSS, so subtract it from the offset.
      // Also subtract 1px per side for the indicator's own border.
      const left = linkRect.left - trackRect.left - 5;
      const width = linkRect.width - 2;

      indicator.style.width = `${width}px`;
      indicator.style.transform = `translateX(${left}px)`;
    }

    function setActive(id: string) {
      if (id === activeId) return;
      activeId = id;

      // Reveal indicator on first call
      if (indicator) indicator.style.opacity = "1";

      let activeLink: HTMLAnchorElement | null = null;
      links.forEach((l) => {
        if (l.dataset.section === id) {
          l.setAttribute("aria-current", "true");
          activeLink = l;
        } else {
          l.removeAttribute("aria-current");
        }
      });
      moveIndicator(activeLink);
    }

    // --- Active section tracking ---
    // IntersectionObserver: native, zero-jitter. Fires only at section boundaries.
    // rootMargin top: -80px compensates the fixed navbar.
    // rootMargin bottom: -60% means a section is "active" once its top enters
    // the upper 40% of the viewport.
    const observer = new IntersectionObserver(
      (entries) => {
        // Among all currently intersecting sections, pick the one closest to the top
        let topEntry: IntersectionObserverEntry | null = null;
        let minTop = Infinity;

        for (const entry of entries) {
          if (entry.isIntersecting && entry.boundingClientRect.top < minTop) {
            minTop = entry.boundingClientRect.top;
            topEntry = entry;
          }
        }

        if (topEntry) {
          setActive(topEntry.target.id);
        }
      },
      {
        rootMargin: "-80px 0px -60% 0px",
        threshold: 0,
      },
    );

    for (const section of sections) {
      observer.observe(section);
    }

    // --- Link clicks ---
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.dataset.section;
        if (!id) return;
        const section = document.getElementById(id);
        section?.scrollIntoView({ behavior: "smooth" });
      });
    });

    // --- Initial state ---
    const hash = window.location.hash.replace("#", "");
    if (hash && sections.some((s) => s.id === hash)) {
      setActive(hash);
      requestAnimationFrame(() => {
        document.getElementById(hash)?.scrollIntoView();
      });
    } else {
      setActive(sections[0].id);
    }

    // Re-position indicator after web fonts load to fix layout shift
    document.fonts.ready.then(() => {
      requestAnimationFrame(() =>
        moveIndicator(
          document.querySelector<HTMLAnchorElement>(
            '.nav-link[aria-current="true"]',
          ),
        ),
      );
    });
  }

  // Defer to next tick so the DOM is fully parsed (inline scripts block the parser)
  setTimeout(initNav, 0);
</script>

<style>
  .nav {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .nav-track {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
    padding: 5px;
    background: rgba(98, 0, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    pointer-events: auto;
  }

  /* ---- Links ---- */
  .nav-link {
    position: relative;
    padding: 0.5rem 1.125rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgb(255 255 255 / 0.8);
    text-decoration: none;
    border-radius: 12px;
    transition: color 0.3s var(--ease-out-quint);
    white-space: nowrap;
    z-index: 1;
  }

  .nav-link:hover {
    color: var(--bg-primary);
  }

  .nav-link[aria-current="true"] {
    color: #000000;
  }

  /* ---- Sliding indicator pill ---- */
  .nav-indicator {
    position: absolute;
    top: 5px;
    bottom: 5px;
    left: 5px;
    background: rgba(255, 255, 255, 1);
    border-radius: 12px;
    border: 1px solid rgb(255 255 255 / 0.05);
    opacity: 0;
    transition:
      transform 0.3s var(--ease-out-quint),
      width 0.3s var(--ease-out-quint),
      opacity 0.12s var(--ease-out-quint);
    pointer-events: none;
  }

  /* ---- CV download button ---- */
  .nav-cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.45rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    border: 1px solid var(--color-border-active);
    border-radius: 12px;
    text-decoration: none;
    pointer-events: auto;
    transition:
      color 0.3s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint),
      border-color 0.3s var(--ease-out-quint);
  }

  .nav-cv-btn:hover {
    color: #fff;
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .nav {
      top: 1rem;
    }

    .nav-link {
      padding: 0.45rem 0.75rem;
      font-size: 0.6875rem;
    }
  }
</style>
