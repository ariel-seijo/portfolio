---
import SectionTransition from "@components/ui/SectionTransition.astro";
import ParticleField from "@components/ui/ParticleField.astro";
import Button from "@components/ui/Button.astro";
import ScrollIndicator from "@components/shared/ScrollIndicator.astro";
---

<SectionTransition sectionId="hero">
  <ParticleField />

  <div class="hero-content stagger-children">
    <p class="hero-eyebrow stagger-1">Full Stack Engineer</p>

    <h1 class="hero-heading stagger-2">
      Arquitectura que
      <span class="hero-accent">convierte complejidad</span>
      en producto.
    </h1>

    <p class="hero-description stagger-3">
      Especialista en sistemas financieros y plataformas de alto tráfico.
      Diseño, construyo y optimizo sistemas que procesan millones de
      operaciones en producción.
    </p>

    <div class="hero-metrics stagger-4">
      <div class="metric">
        <span class="metric-value">5+</span>
        <span class="metric-label">Años diseñando sistemas</span>
      </div>
      <div class="metric-divider" aria-hidden="true"></div>
      <div class="metric">
        <span class="metric-value">99.99%</span>
        <span class="metric-label">Uptime en producción</span>
      </div>
    </div>

    <div class="hero-ctas stagger-5">
      <Button variant="filled" size="lg" href="/cv.pdf" download>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        Descargar CV
      </Button>
      <Button variant="outlined" size="lg" href="#projects">
        Ver Proyectos
      </Button>
      <Button variant="ghost" size="lg" href="#contact">
        Contacto
      </Button>
    </div>
  </div>

  <ScrollIndicator />
</SectionTransition>

<style>
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 44rem;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .hero-heading {
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-description {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 32rem;
    margin-bottom: var(--space-8);
  }

  .hero-metrics {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.025em;
  }

  .metric-label {
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .metric-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border-default);
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 1023px) {
    .hero-content {
      max-width: none;
    }

    .hero-metrics {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .metric-divider {
      width: 100%;
      height: 1px;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
