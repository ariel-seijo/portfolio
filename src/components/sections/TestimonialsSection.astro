---
import { TESTIMONIALS, getAvatarColor } from "@data/testimonials";

const PAGES: Array<typeof TESTIMONIALS> = [];
for (let i = 0; i < TESTIMONIALS.length; i += 2) {
  PAGES.push(TESTIMONIALS.slice(i, i + 2));
}
---

<section id="testimonios" class="section-wrapper testimonials-section">
  <div class="section-heading reveal-item">
    <h2 class="title-block">
      <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
      <span class="title-main">Testimonios</span>
      <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
    </h2>
  </div>

  <div class="testimonials-stage reveal-item">
    <div class="pages-container" id="pages-container">
      {
        PAGES.map((page, pi) => (
          <div
            class={`page${pi === 0 ? " active" : ""}`}
            data-page={pi}
            aria-hidden={pi === 0 ? "false" : "true"}
          >
            {
              page.map((t) => {
                const color = getAvatarColor(t.name);
                return (
                  <div
                    class="testimonial-card"
                    style={`--avatar-color: ${color}`}
                    role="article"
                    aria-label={`Testimonio de ${t.name}`}
                  >
                    <div class="card-header">
                      <div class="avatar" aria-hidden="true">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="24" cy="24" r="23" fill={color} opacity="0.15" />
                          <circle cx="24" cy="24" r="21" fill={color} opacity="0.3" />
                          <text
                            x="24"
                            y="24"
                            text-anchor="middle"
                            dominant-baseline="central"
                            fill="white"
                            font-size="16"
                            font-family="Inter, -apple-system, sans-serif"
                            font-weight="600"
                          >{t.initials}</text>
                        </svg>
                      </div>
                      <div class="header-info">
                        <span class="person-name">{t.name}</span>
                        <a
                          href={t.linkedinUrl}
                          class="linkedin-btn"
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`LinkedIn de ${t.name}`}
                        >
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                        </a>
                      </div>
                    </div>

                    <span class="relationship-tag">{t.relationship}</span>

                    <p class="testimonial-text">{t.message}</p>

                    <button class="expand-btn js-expand-btn" aria-expanded="false">
                      <span class="expand-text">Leer más</span>
                      <svg class="expand-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </button>
                  </div>
                );
              })
            }
          </div>
        ))
      }
    </div>

    <div class="page-dots" role="tablist" aria-label="Navegar páginas de testimonios">
      {
        PAGES.map((_, i) => (
          <button
            class={`page-dot${i === 0 ? " active" : ""}`}
            data-page={i}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`Página ${i + 1} de testimonios`}
          ></button>
        ))
      }
    </div>
  </div>
</section>

<script>
  function initTestimonials() {
    const pages = document.querySelectorAll<HTMLDivElement>(".page");
    const dots = document.querySelectorAll<HTMLButtonElement>(".page-dot");

    function goToPage(index: number) {
      pages.forEach((p) => {
        p.classList.remove("active");
        p.setAttribute("aria-hidden", "true");
      });
      dots.forEach((d) => {
        d.classList.remove("active");
        d.setAttribute("aria-selected", "false");
      });

      const targetPage = pages[index];
      const targetDot = dots[index];
      if (!targetPage || !targetDot) return;

      targetPage.classList.add("active");
      targetPage.setAttribute("aria-hidden", "false");
      targetDot.classList.add("active");
      targetDot.setAttribute("aria-selected", "true");
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.dataset.page);
        if (!Number.isNaN(idx)) goToPage(idx);
      });
    });

    // Expand/collapse on card click
    document.querySelectorAll<HTMLDivElement>(".testimonial-card").forEach((card) => {
      card.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest(".linkedin-btn") || target.closest("a")) return;

        const textEl = card.querySelector<HTMLParagraphElement>(".testimonial-text");
        const btn = card.querySelector<HTMLButtonElement>(".js-expand-btn");
        const expandText = btn?.querySelector<HTMLSpanElement>(".expand-text");
        const chevron = btn?.querySelector<SVGSVGElement>(".expand-chevron");

        const expanded = card.classList.toggle("expanded");

        if (expanded) {
          if (textEl) textEl.style.maxHeight = textEl.scrollHeight + "px";
          if (expandText) expandText.textContent = "Leer menos";
          if (chevron) chevron.style.transform = "rotate(180deg)";
          btn?.setAttribute("aria-expanded", "true");
        } else {
          if (textEl) textEl.style.maxHeight = "";
          if (expandText) expandText.textContent = "Leer más";
          if (chevron) chevron.style.transform = "";
          btn?.setAttribute("aria-expanded", "false");
        }
      });
    });
  }

  initTestimonials();
  document.addEventListener("astro:page-load", initTestimonials);
</script>

<style>
  .testimonials-section {
    flex-direction: column;
    max-width: none;
    padding: 0;
  }

  .section-heading {
    padding: 0 var(--content-padding);
  }

  /* ---- Stage ---- */
  .testimonials-stage {
    width: 100%;
    max-width: 1000px;
    padding-inline: var(--content-padding);
  }

  /* ---- Pages container ---- */
  .pages-container {
    position: relative;
    min-height: 280px;
  }

  .page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    opacity: 0;
    pointer-events: none;
    position: absolute;
    inset: 0;
    transition: opacity 0.4s var(--ease-out-quint);
  }

  .page.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
    inset: auto;
  }

  /* ---- Card ---- */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8);
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transform: translateY(0);
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.35s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .testimonial-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 70% at 20% 20%,
      rgb(139 92 246 / 0.04) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
    pointer-events: none;
    border-radius: 16px;
  }

  .testimonial-card:hover {
    border-color: rgb(139 92 246 / 0.25);
    transform: translateY(-3px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.35),
      0 0 40px rgb(139 92 246 / 0.04);
    background: rgb(19 19 23 / 0.6);
  }

  .testimonial-card:hover::before {
    opacity: 1;
  }

  .testimonial-card.expanded {
    border-color: rgb(139 92 246 / 0.25);
    background: rgb(19 19 23 / 0.65);
  }

  /* ---- Header ---- */
  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 2px var(--avatar-color, var(--color-accent));
    transition: box-shadow 0.3s var(--ease-out-quint);
  }

  .testimonial-card:hover .avatar {
    box-shadow: 0 0 0 3px var(--avatar-color, var(--color-accent));
  }

  .avatar svg {
    display: block;
  }

  .header-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
    flex: 1;
  }

  .person-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ---- LinkedIn ---- */
  .linkedin-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgb(10 102 194 / 0.15);
    color: #0a66c2;
    transition:
      background 0.25s var(--ease-out-quint),
      transform 0.25s var(--ease-spring),
      color 0.25s var(--ease-out-quint);
  }

  .linkedin-btn:hover {
    background: #0a66c2;
    color: white;
    transform: scale(1.1);
  }

  /* ---- Relationship tag ---- */
  .relationship-tag {
    display: inline-block;
    align-self: flex-start;
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    padding: var(--space-1) var(--space-3);
    background: rgb(255 255 255 / 0.04);
    border: 1px solid var(--color-border-default);
    border-radius: 999px;
    line-height: 1.4;
    letter-spacing: 0.01em;
    transition:
      border-color 0.3s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .testimonial-card:hover .relationship-tag {
    border-color: rgb(255 255 255 / 0.1);
    background: rgb(255 255 255 / 0.06);
  }

  /* ---- Text ---- */
  .testimonial-text {
    font-size: clamp(0.8125rem, 0.4vw + 0.7rem, 0.9375rem);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-height: calc(1.65em * 3);
    transition: max-height 0.45s var(--ease-out-quint);
  }

  .testimonial-card.expanded .testimonial-text {
    -webkit-line-clamp: unset;
  }

  /* ---- Expand button ---- */
  .expand-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    align-self: flex-start;
    background: none;
    border: none;
    padding: var(--space-1) var(--space-2);
    margin-top: calc(var(--space-2) * -1);
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-accent);
    cursor: pointer;
    border-radius: 6px;
    transition:
      background 0.2s var(--ease-out-quint),
      color 0.2s var(--ease-out-quint);
  }

  .expand-btn:hover {
    background: var(--color-accent-muted);
    color: var(--color-accent-hover);
  }

  .expand-chevron {
    transition: transform 0.35s var(--ease-out-quint);
  }

  /* ---- Page dots ---- */
  .page-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    padding-top: var(--space-8);
  }

  .page-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgb(255 255 255 / 0.2);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition:
      border-color 0.3s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint),
      transform 0.25s var(--ease-spring);
  }

  .page-dot:hover {
    border-color: rgb(255 255 255 / 0.4);
    transform: scale(1.2);
  }

  .page-dot.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    transform: scale(1.15);
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 860px) {
    .testimonials-stage {
      max-width: 600px;
    }

    .page {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .testimonial-card {
      padding: var(--space-7);
    }

    .page-dots {
      padding-top: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .testimonials-stage {
      padding-inline: var(--space-4);
    }

    .page {
      gap: var(--space-4);
    }

    .testimonial-card {
      padding: var(--space-6);
      gap: var(--space-4);
      border-radius: 14px;
    }

    .card-header {
      gap: var(--space-3);
    }

    .avatar {
      width: 40px;
      height: 40px;
    }

    .avatar svg {
      width: 40px;
      height: 40px;
    }

    .testimonial-text {
      font-size: 0.8125rem;
      max-height: calc(1.6em * 3);
    }

    .page-dots {
      padding-top: var(--space-5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-card,
    .testimonial-text,
    .expand-chevron,
    .linkedin-btn,
    .page {
      transition: none;
    }
  }
</style>
