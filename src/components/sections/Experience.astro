---
import SectionTransition from "@components/ui/SectionTransition.astro";
import SectionHeading from "@components/shared/SectionHeading.astro";
import Tag from "@components/ui/Tag.astro";

const experiences = [
  {
    period: "2024 · Presente",
    title: "Senior Full Stack Engineer",
    company: "TechFinance Corp",
    location: "Remoto",
    description:
      "Arquitectura y desarrollo de la plataforma core de procesamiento de pagos con Go, Kafka y PostgreSQL.",
    achievements: [
      "Rediseño del pipeline de eventos: -60% latencia p99",
      "Migración de monolith a microservicios: 12 servicios en producción",
      "Implementación de circuit breakers y retry policies con zero-downtime deployments",
    ],
    stack: ["Go", "Kafka", "PostgreSQL", "gRPC", "Kubernetes", "Terraform"],
  },
  {
    period: "2022 · 2024",
    title: "Full Stack Developer",
    company: "DataStream Analytics",
    location: "Remoto",
    description:
      "Desarrollo full stack de dashboards de monitoreo financiero en tiempo real con Next.js y WebSockets.",
    achievements: [
      "Dashboard con +10K usuarios activos diarios",
      "Sistema de alertas predictivas con ML — +50% detección de anomalías",
      "Lideré migración a TypeScript strict en codebase de 200K líneas",
    ],
    stack: ["Next.js", "TypeScript", "Python", "WebSocket", "D3.js", "Redis"],
  },
  {
    period: "2022 · Inicio",
    title: "Software Engineer",
    company: "Startup Fintech",
    location: "Buenos Aires",
    description:
      "Primer engineer de una fintech seed-stage. Construí el MVP que levantó la Serie A.",
    achievements: [
      "MVP lanzado en 3 meses — funcionalidad completa de onboarding, KYC y procesamiento",
      "Diseñé el schema de base de datos y la arquitectura inicial de microservicios",
    ],
    stack: ["React", "Node.js", "PostgreSQL", "Docker", "AWS"],
  },
];
---

<SectionTransition sectionId="experience">
  <div class="section-inner scrollable-inner">
    <SectionHeading
      title="Experiencia"
      subtitle="Trayectoria construyendo sistemas que escalan."
    />

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item">
          <!-- Dot + line -->
          <div class="timeline-track">
            <div class="timeline-dot" aria-hidden="true"></div>
            {i < experiences.length - 1 && (
              <div class="timeline-line" aria-hidden="true"></div>
            )}
          </div>

          <!-- Content -->
          <div class="timeline-content">
            <span class="timeline-period">{exp.period}</span>
            <h3 class="timeline-title">
              {exp.title}
              <span class="timeline-company"> · {exp.company}</span>
            </h3>
            <span class="timeline-location">{exp.location}</span>

            <p class="timeline-desc">{exp.description}</p>

            <!-- Achievements -->
            <ul class="timeline-achievements">
              {exp.achievements.map((a) => (
                <li class="timeline-achievement">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {a}
                </li>
              ))}
            </ul>

            <!-- Stack tags -->
            <div class="timeline-tags">
              {exp.stack.map((tech) => (
                <Tag size="sm">{tech}</Tag>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</SectionTransition>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    padding-left: var(--space-4);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: var(--space-4);
  }

  /* Track: dot + line */
  .timeline-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--color-border-default);
    margin-top: var(--space-2);
    min-height: var(--space-8);
  }

  /* Content */
  .timeline-content {
    padding-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-accent);
  }

  .timeline-title {
    font-size: var(--text-h2);
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .timeline-company {
    color: var(--color-text-secondary);
    font-weight: 400;
  }

  .timeline-location {
    font-size: var(--text-body-sm);
    color: var(--color-text-tertiary);
  }

  .timeline-desc {
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .timeline-achievements {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .timeline-achievement {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-body-sm);
    color: var(--color-success);
    font-weight: 500;
    line-height: 1.5;
  }

  .timeline-achievement svg {
    flex-shrink: 0;
    margin-top: 4px;
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  @media (max-width: 640px) {
    .timeline {
      padding-left: 0;
    }

    .timeline-title {
      font-size: var(--text-h3);
    }
  }
</style>
