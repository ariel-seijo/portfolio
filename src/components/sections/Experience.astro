<section id="experiencia" class="snap-section experience-section">
  <div class="experience">
    <!-- Header -->
    <header class="section-header">
      <h2 class="section-heading">Experiencia Laboral</h2>
      <div class="section-divider" aria-hidden="true"></div>
    </header>

    <!-- Timeline -->
    <div class="timeline">
      <div class="timeline-track" aria-hidden="true">
        <div class="timeline-dot">
          <span class="timeline-pulse"></span>
        </div>
        <div class="timeline-line"></div>
      </div>
      <article class="timeline-card">
        <time class="job-date" datetime="2026">2026 — ???</time>
        <h3 class="job-title">Desarrollador</h3>
        <p class="job-company">???</p>
        <p class="job-desc">
          Desarrollo de soluciones tecnológicas utilizando... bla, bla, bla.
        </p>
      </article>
    </div>

    <!-- Quote / Diálogo -->
    <div class="quote">
      <div class="quote-avatar">
        <img
          src="/avatar-experience.webp"
          alt="Avatar de Ariel"
          loading="lazy"
        />
      </div>
      <blockquote class="quote-bubble">
        <p class="quote-text">Estoy reservando esta sección para tu empresa.</p>
      </blockquote>
    </div>
  </div>
</section>

<style>
  /* =============================================
     CONTAINER
     ============================================= */

  .experience {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    padding: var(--space-10) var(--content-padding);
    max-width: 800px;
    width: 100%;
  }

  /* =============================================
     SECTION HEADER
     ============================================= */

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .section-heading {
    font-size: var(--text-display);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
  }

  .section-divider {
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    opacity: 0.5;
  }

  /* =============================================
     TIMELINE
     ============================================= */

  .timeline {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  /* ---- Track (line + dot) ---- */

  .timeline-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .timeline-dot {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 16px rgb(139 92 246 / 0.5);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .timeline-pulse {
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    opacity: 0;
    animation: dot-pulse 2.5s var(--ease-out-quint) infinite;
  }

  .timeline-line {
    width: 2px;
    flex: 1;
    min-height: 40px;
    background: linear-gradient(
      to bottom,
      var(--color-accent),
      rgb(139 92 246 / 0.2) 40%,
      transparent
    );
    margin-top: 8px;
  }

  /* ---- Card ---- */

  .timeline-card {
    background: rgb(139 92 246 / 0.04);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgb(139 92 246 / 0.12);
    border-radius: 16px;
    padding: var(--space-6);
    transition:
      border-color 0.3s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint),
      transform 0.25s var(--ease-out-quint);
  }

  .timeline-card:hover {
    border-color: rgb(139 92 246 / 0.25);
    background: rgb(139 92 246 / 0.07);
    transform: translateY(-2px);
  }

  .job-date {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .job-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .job-company {
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
    margin: var(--space-1) 0 var(--space-3);
  }

  .job-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--space-4);
  }

  .job-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* ---- Pill (same pattern as Profile) ---- */

  .pill {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--color-accent-muted);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-active);
    border-radius: 8px;
    transition:
      color 0.2s var(--ease-out-quint),
      background 0.2s var(--ease-out-quint),
      border-color 0.2s var(--ease-out-quint);
  }

  .pill:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-hover-2);
    border-color: rgb(139 92 246 / 0.25);
  }

  /* =============================================
     QUOTE / DIÁLOGO
     ============================================= */

  .quote {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    max-width: 620px;
  }

  /* ---- Avatar ---- */

  .quote-avatar {
    flex-shrink: 0;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    padding: 4px;
    background: conic-gradient(
      from 0deg,
      var(--color-accent),
      rgb(139 92 246 / 0.25) 30%,
      transparent 55%,
      rgb(139 92 246 / 0.25) 80%,
      var(--color-accent)
    );
  }

  .quote-avatar img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  /* ---- Bubble ---- */

  .quote-bubble {
    position: relative;
    background: rgb(139 92 246 / 0.06);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgb(139 92 246 / 0.14);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    animation: float 4s ease-in-out infinite;
  }

  /* Bubble tail (desktop: pointing left) */
  .quote-bubble::before {
    content: "";
    position: absolute;
    left: -7px;
    top: 28px;
    width: 14px;
    height: 14px;
    background: rgb(139 92 246 / 0.06);
    border-left: 1px solid rgb(139 92 246 / 0.14);
    border-bottom: 1px solid rgb(139 92 246 / 0.14);
    transform: rotate(45deg);
    border-bottom-left-radius: 3px;
  }

  .quote-text {
    font-size: 1rem;
    font-weight: 350;
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .quote-attribution {
    display: block;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0.75;
    text-align: right;
    position: relative;
    z-index: 1;
  }

  /* =============================================
     ANIMATIONS
     ============================================= */

  @keyframes dot-pulse {
    0% {
      transform: scale(0.8);
      opacity: 0.8;
    }
    70% {
      transform: scale(1.8);
      opacity: 0;
    }
    100% {
      transform: scale(0.8);
      opacity: 0;
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 768px) {
    .experience {
      gap: var(--space-8);
      padding: var(--space-8) var(--content-padding);
    }

    .timeline {
      grid-template-columns: 28px 1fr;
      gap: var(--space-5);
    }

    .timeline-card {
      padding: var(--space-5);
    }

    .quote {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .experience {
      gap: var(--space-6);
      padding: var(--space-6) var(--space-5);
    }

    .section-heading {
      font-size: clamp(2rem, 6vw, var(--text-display));
    }

    /* Timeline: reduce card padding */
    .timeline {
      grid-template-columns: 24px 1fr;
      gap: var(--space-4);
    }

    .timeline-card {
      padding: var(--space-4);
    }

    .job-title {
      font-size: 1rem;
    }

    /* Quote: stack vertically, tail points up */
    .quote {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .quote-avatar {
      width: 64px;
      height: 64px;
      padding: 3px;
    }

    .quote-bubble {
      animation: none;
    }

    /* Reposition tail to point up */
    .quote-bubble::before {
      left: 50%;
      top: -7px;
      margin-left: -7px;
      border-left: 1px solid rgb(139 92 246 / 0.14);
      border-bottom: none;
      border-top: 1px solid rgb(139 92 246 / 0.14);
      border-bottom-left-radius: 0;
    }

    .quote-text {
      font-size: 0.875rem;
    }

    .quote-attribution {
      text-align: center;
    }
  }
</style>
