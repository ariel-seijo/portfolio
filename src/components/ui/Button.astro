---
import { cn } from "@utils/cn";

export interface Props {
  variant?: "filled" | "outlined" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  download?: string | boolean;
  class?: string;
  [key: string]: any;
}

const {
  variant = "filled",
  size = "md",
  href,
  download,
  class: className,
  ...rest
} = Astro.props;

const base = cn(
  "btn",
  `btn-${variant}`,
  `btn-${size}`,
  className
);

const Tag = href ? "a" : "button";
const attrs = {
  ...rest,
  ...(href ? { href, ...(download ? { download: download === true ? "" : download } : {}) } : {}),
};
---

<Tag class={base} {...attrs}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 500;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s var(--ease-in-out-circ);
    text-decoration: none;
    white-space: nowrap;
    user-select: none;
    position: relative;
    overflow: hidden;
  }

  /* === SIZES === */
  .btn-sm {
    height: 2.25rem;
    padding: 0 var(--space-4);
    font-size: var(--text-body-sm);
  }

  .btn-md {
    height: 2.75rem;
    padding: 0 var(--space-5);
    font-size: var(--text-body-sm);
  }

  .btn-lg {
    height: 3.25rem;
    padding: 0 var(--space-8);
    font-size: var(--text-body);
  }

  /* === FILLED (accent violet) === */
  .btn-filled {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-filled:hover {
    background: var(--color-accent-hover);
    transform: scale(1.02);
  }

  .btn-filled:active {
    transform: scale(0.98);
  }

  /* === OUTLINED === */
  .btn-outlined {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
  }

  .btn-outlined:hover {
    border-color: var(--color-border-hover);
    background: var(--color-accent-muted);
  }

  /* === GHOST === */
  .btn-ghost {
    background: transparent;
    color: var(--color-text-secondary);
  }

  .btn-ghost:hover {
    color: var(--color-text-primary);
    background: rgb(255 255 255 / 0.04);
  }
</style>
