---
import { cn } from "@utils/cn";

export interface Props {
  class?: string;
  color?: "accent" | "success" | "warning" | "default";
  size?: "sm" | "md";
}

const { class: className, color = "default", size = "md" } = Astro.props;
---

<span class={cn("tag", `tag-${color}`, `tag-${size}`, className)}>
  <slot />
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: 500;
    border-radius: 6px;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .tag-sm {
    font-size: 0.6875rem;
    padding: 2px 8px;
  }

  .tag-md {
    font-size: var(--text-caption);
    padding: 3px 10px;
  }

  .tag-default {
    background: var(--color-bg-elevated);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-default);
  }

  .tag-accent {
    background: var(--color-accent-muted);
    color: var(--color-accent-hover);
    border: 1px solid rgb(139 92 246 / 0.15);
  }

  .tag-success {
    background: var(--color-success-muted);
    color: var(--color-success);
    border: 1px solid rgb(74 222 128 / 0.15);
  }

  .tag-warning {
    background: var(--color-warning-muted);
    color: var(--color-warning);
    border: 1px solid rgb(251 191 36 / 0.15);
  }
</style>
