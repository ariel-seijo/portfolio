---
import { cn } from "@utils/cn";

export interface Props {
  name: string;
  label?: string;
  type?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  class?: string;
}

const {
  name,
  label,
  type = "text",
  placeholder,
  rows,
  required = false,
  class: className,
} = Astro.props;

const id = `field-${name}`;
const isTextarea = type === "textarea";
---

<div class={cn("input-group", className)}>
  {label && <label for={id} class="input-label">{label}</label>}

  {isTextarea ? (
    <textarea
      id={id}
      name={name}
      placeholder={placeholder}
      rows={rows ?? 4}
      required={required}
      class="input-field input-textarea"
    ></textarea>
  ) : (
    <input
      id={id}
      name={name}
      type={type}
      placeholder={placeholder}
      required={required}
      class="input-field"
    />
  )}
</div>

<style>
  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
  }

  .input-label {
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: -0.005em;
  }

  .input-field {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 10px;
    color: var(--color-text-primary);
    font-size: var(--text-body-sm);
    transition: border-color 0.2s var(--ease-in-out-circ),
      box-shadow 0.2s var(--ease-in-out-circ);
    outline: none;
    resize: vertical;
  }

  .input-field::placeholder {
    color: var(--color-text-tertiary);
  }

  .input-field:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-muted);
  }

  .input-textarea {
    min-height: 100px;
    line-height: 1.6;
  }
</style>
