---
import { cn } from "@utils/cn";

export interface Props {
  class?: string;
  hasGlow?: boolean;
}

const { class: className, hasGlow = true } = Astro.props;
---

<article
  class={cn(
    "card",
    hasGlow && "card-light-border",
    className
  )}
>
  <slot />
</article>

<style>
  .card {
    position: relative;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 16px;
    padding: var(--space-6);
    overflow: hidden;
    transition: border-color 0.3s var(--ease-in-out-circ),
      transform 0.2s var(--ease-out-expo),
      box-shadow 0.3s var(--ease-in-out-circ);
  }

  /* Light border effect (only when .card-light-border) */
  .card-light-border::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgb(139 92 246 / 0.2),
      transparent 50%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s var(--ease-in-out-circ);
    z-index: 2;
  }

  .card-light-border:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .card-light-border:hover::before {
    opacity: 1;
  }
</style>
