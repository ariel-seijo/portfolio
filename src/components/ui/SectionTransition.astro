---
export interface Props {
  sectionId: string;
  class?: string;
}

const { sectionId, class: className } = Astro.props;
---

<section
  id={sectionId}
  class:list={["section", className]}
  aria-hidden="true"
>
  <div class="section-inner">
    <slot />
  </div>
</section>

<style>
  .section {
    position: absolute;
    inset: 0;
    top: var(--navbar-height);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Active state */
  .section-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 1;
  }

  /* Exit animations */
  .section-exit {
    transition: opacity 0.5s var(--ease-out-expo),
      transform 0.5s var(--ease-out-expo);
  }

  .exit-up {
    transform: translateY(-30px);
    opacity: 0;
  }

  .exit-down {
    transform: translateY(30px);
    opacity: 0;
  }

  /* Enter animations */
  .section-enter {
    z-index: 2;
    transition: opacity 0.45s var(--ease-out-expo) 0.05s,
      transform 0.55s var(--ease-out-expo);
  }

  .enter-from-bottom {
    transform: translateY(40px);
    opacity: 0;
  }

  .enter-from-top {
    transform: translateY(-40px);
    opacity: 0;
  }

  .section-active.section-enter {
    transform: translateY(0);
    opacity: 1;
  }

  /* Inner content wrapper */
  .section-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-10) var(--content-padding);
    overflow-y: auto;
  }

  /* Inner scroll for sections that need it */
  .section-inner.scrollable-inner {
    justify-content: flex-start;
    padding-top: var(--space-12);
  }

  /* Mobile */
  @media (max-width: 1023px) {
    .section {
      position: relative;
      inset: auto;
      top: 0;
      opacity: 1;
      pointer-events: auto;
      min-height: 100vh;
      min-height: 100dvh;
    }

    .section-inner {
      padding-top: calc(var(--navbar-height) + var(--space-8));
    }
  }
</style>
